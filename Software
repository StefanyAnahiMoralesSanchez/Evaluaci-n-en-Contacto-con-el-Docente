package main

/*
====================================================
 PROYECTO: Biblioteca Digital - API + Web
----------------------------------------------------
Este programa levanta un servidor web en Go que:

1) Sirve una página web moderna en "/"
2) Expone un endpoint JSON en "/api/books"

La página consume la API usando fetch() y muestra
los datos dinámicamente con buscador y filtros.
====================================================
*/

import (
	"encoding/json"
	"fmt"
	"net/http"
	"time"
)

// ====================================================
//  MODELO DE DATOS
// ----------------------------------------------------
// Representa la estructura de un libro en la API.
// Las etiquetas json permiten serializar correctamente.
// ====================================================

type Book struct {
	ID        int       json:"id"
	Title     string    json:"title"
	Author    string    json:"author"
	Format    string    json:"format"
	FilePath  string    json:"file_path"
	CreatedAt time.Time json:"created_at"
	UpdatedAt time.Time json:"updated_at"
}

// ====================================================
//  DATOS SIMULADOS
// ----------------------------------------------------
// Simula una base de datos.
// En un proyecto real, aquí se conectaría a
// PostgreSQL, MySQL o MongoDB.
// ====================================================

var books = []Book{
	{1, "El Aleph", "Jorge Luis Borges", "epub", "C:/ebooks/el_aleph.epub", time.Now().Add(-200 * time.Hour), time.Now().Add(-2 * time.Hour)},
	{2, "Cien años de soledad", "Gabriel García Márquez", "pdf", "https://ejemplo.com/cien.pdf", time.Now().Add(-300 * time.Hour), time.Now().Add(-6 * time.Hour)},
	{3, "Don Quijote de la Mancha", "Miguel de Cervantes", "epub", "https://ejemplo.com/quijote.epub", time.Now().Add(-500 * time.Hour), time.Now().Add(-20 * time.Hour)},
	{4, "1984", "George Orwell", "pdf", "https://ejemplo.com/1984.pdf", time.Now().Add(-720 * time.Hour), time.Now().Add(-50 * time.Hour)},
	{5, "El Hobbit", "J.R.R. Tolkien", "azw3", "C:/ebooks/hobbit.azw3", time.Now().Add(-600 * time.Hour), time.Now().Add(-60 * time.Hour)},
}

// ====================================================
//  FUNCIÓN PRINCIPAL
// ----------------------------------------------------
// Configura el servidor HTTP y define las rutas.
// ====================================================

func main() {

	// Crear router
	mux := http.NewServeMux()

	// Ruta principal (HTML)
	mux.HandleFunc("/", serveHome)

	// Endpoint API JSON
	mux.HandleFunc("/api/books", serveAPI)

	fmt.Println("Servidor ejecutándose en http://localhost:8080")

	// Iniciar servidor
	if err := http.ListenAndServe(":8080", mux); err != nil {
		panic(err)
	}
}

// ====================================================
//  HANDLER: API JSON
// ----------------------------------------------------
// Devuelve la lista de libros en formato JSON.
// Método permitido: GET
// ====================================================

func serveAPI(w http.ResponseWriter, r *http.Request) {

	// Validar método HTTP
	if r.Method != http.MethodGet {
		http.Error(w, "Method Not Allowed", http.StatusMethodNotAllowed)
		return
	}

	// Indicar que la respuesta es JSON
	w.Header().Set("Content-Type", "application/json")

	// Convertir slice a JSON y enviarlo
	_ = json.NewEncoder(w).Encode(books)
}

// ====================================================
//  HANDLER: Página Web
// ----------------------------------------------------
// Devuelve el HTML que contiene el diseño moderno,
// buscador y lógica JavaScript.
// ====================================================

func serveHome(w http.ResponseWriter, r *http.Request) {

	// Solo permitir acceso a la raíz exacta
	if r.URL.Path != "/" {
		http.NotFound(w, r)
		return
	}

	w.Header().Set("Content-Type", "text/html; charset=utf-8")

	// Renderizar página
	fmt.Fprint(w, pageHTML)
}

