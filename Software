<script>
(function(){
  var state = {
    all: [],
    filtered: [],
    q: '',
    fmt: ''
  };

  var rows = document.getElementById('rows');
  var qInput = document.getElementById('q');
  var fmtSel = document.getElementById('fmt');
  var totalEl = document.getElementById('total');
  var shownEl = document.getElementById('shown');
  var statusEl = document.getElementById('status');
  var reloadBtn = document.getElementById('reloadBtn');
  var themeBtn = document.getElementById('themeBtn');

  // Tema (persistente)
  var savedTheme = localStorage.getItem('theme');
  if(savedTheme === 'light'){ document.documentElement.setAttribute('data-theme','light'); themeBtn.textContent = '☀️ Tema'; }
  else { document.documentElement.removeAttribute('data-theme'); themeBtn.textContent = '🌙 Tema'; }

  themeBtn.addEventListener('click', function(){
    var isLight = document.documentElement.getAttribute('data-theme') === 'light';
    if(isLight){
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme','dark');
      themeBtn.textContent = '🌙 Tema';
    } else {
      document.documentElement.setAttribute('data-theme','light');
      localStorage.setItem('theme','light');
      themeBtn.textContent = '☀️ Tema';
    }
  });

  // Atajo Ctrl+K para enfocar buscador
  document.addEventListener('keydown', function(e){
    if((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')){
      e.preventDefault();
      qInput.focus();
      qInput.select();
    }
  });

  reloadBtn.addEventListener('click', function(){ load(); });

  qInput.addEventListener('input', function(){
    state.q = (qInput.value || '').trim().toLowerCase();
    apply();
  });

  fmtSel.addEventListener('change', function(){
    state.fmt = (fmtSel.value || '').trim().toLowerCase();
    apply();
  });

  function load(){
    statusEl.textContent = 'cargando…';
    rows.innerHTML = '<tr><td colspan="6" class="empty">Cargando…</td></tr>';

    fetch('/api/books')
      .then(function(res){
        if(!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then(function(data){
        if(!Array.isArray(data)) data = [];
        state.all = data.slice();
        totalEl.textContent = String(state.all.length);

        buildFormats(state.all);
        statusEl.textContent = 'ok';
        apply();
      })
      .catch(function(err){
        statusEl.textContent = 'error';
        rows.innerHTML = '<tr><td colspan="6" class="empty" style="color:#ff4d6d">Error: ' + escapeHtml(String(err)) + '</td></tr>';
        totalEl.textContent = '0';
        shownEl.textContent = '0';
      });
  }

  function buildFormats(list){
    var set = {};
    for(var i=0;i<list.length;i++){
      var f = (list[i].format || '').toString().toLowerCase().trim();
      if(f) set[f] = true;
    }
    var formats = Object.keys(set).sort();

    // Mantener "Todos"
    while(fmtSel.options.length > 1) fmtSel.remove(1);

    for(var j=0;j<formats.length;j++){
      var opt = document.createElement('option');
      opt.value = formats[j];
      opt.textContent = formats[j].toUpperCase();
      fmtSel.appendChild(opt);
    }
  }

  function apply(){
    var q = state.q;
    var fmt = state.fmt;

    state.filtered = state.all.filter(function(b){
      var title = (b.title || '').toString().toLowerCase();
      var author = (b.author || '').toString().toLowerCase();
      var format = (b.format || '').toString().toLowerCase();
      var file = (b.file_path || '').toString().toLowerCase();

      if(fmt && format !== fmt) return false;

      if(!q) return true;
      return title.indexOf(q) !== -1 ||
             author.indexOf(q) !== -1 ||
             format.indexOf(q) !== -1 ||
             file.indexOf(q) !== -1 ||
             String(b.id || '').indexOf(q) !== -1;
    });

    render(state.filtered);
  }

  function render(list){
    shownEl.textContent = String(list.length);

    if(!list.length){
      rows.innerHTML = '<tr><td colspan="6" class="empty">No hay resultados.</td></tr>';
      return;
    }

    rows.innerHTML = list.map(function(b){
      var file = (b.file_path || '');
      var isUrl = startsWith(file, 'http://') || startsWith(file, 'https://');
      var link = isUrl
        ? '<a href="' + escapeHtml(file) + '" target="_blank" rel="noopener">abrir</a>'
        : '<span class="muted">' + escapeHtml(file) + '</span>';

      var updated = b.updated_at ? new Date(b.updated_at).toLocaleString() : '';

      return '' +
        '<tr>' +
          '<td>' + escapeHtml(b.id ?? '') + '</td>' +
          '<td>' + escapeHtml(b.title ?? '') + '</td>' +
          '<td>' + escapeHtml(b.author ?? '') + '</td>' +
          '<td><span class="tag">' + escapeHtml((b.format ?? '').toString().toUpperCase()) + '</span></td>' +
          '<td>' + link + '</td>' +
          '<td class="muted">' + escapeHtml(updated) + '</td>' +
        '</tr>';
    }).join('');
  }

  function escapeHtml(s){
    return String(s)
      .replaceAll('&','&amp;')
      .replaceAll('<','&lt;')
      .replaceAll('>','&gt;')
      .replaceAll('"','&quot;')
      .replaceAll("'","&#39;");
  }

  function startsWith(s, prefix){
    s = (s || '').toString().toLowerCase();
    prefix = (prefix || '').toString().toLowerCase();
    return s.slice(0, prefix.length) === prefix;
  }

  load();
})();
</script>
